---
layout: null
permalink: /search.json
---
[
  {% for post in site.posts %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "date": {{ post.date | date: "%Y.%m.%d" | jsonify }},
      "topic": {% if post.topic %}{% assign topic_label = post.topic %}{% for topic in site.data.coding_topics %}{% if topic.slug == post.topic %}{% assign topic_label = topic.title %}{% endif %}{% endfor %}{{ topic_label | jsonify }}{% elsif post.categories contains "life" %}"Life"{% else %}"Post"{% endif %},
      "excerpt": {{ post.excerpt | strip_html | normalize_whitespace | truncate: 140 | jsonify }},
      "tags": {{ post.tags | join: " " | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
